generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid())
  firebaseUid       String             @unique
  email             String             @unique
  firstName         String?
  lastName          String?
  phone             String?
  createdAt         DateTime           @default(now())
  companyId         String?
  locationId        String?
  role              Role
  emailLogs         EmailLog[]
  files             File[]
  notifications     Notification[]
  pharmacistProfile PharmacistProfile?
  company           Company?           @relation(fields: [companyId], references: [id])
  location          Location?          @relation(fields: [locationId], references: [id])
  allowedCompanies  Company[]          @relation("ManagerAllowedCompanies")

  @@index([companyId])
  @@index([locationId])
}

model Company {
  id                    String                        @id @default(uuid())
  approved              Boolean                       @default(true)
  name                  String                        @unique
  email                 String?
  phone                 String?
  address               String?
  city                  String?
  province              String?
  postalCode            String?
  createdAt             DateTime                      @default(now())
  GSTNumber             String?
  legalName             String?
  contactEmail          String?
  contactName           String?
  contactPhone          String?
  timezone              String                        @default("America/Edmonton")
  files                 File[]
  locations             Location[]
  pharmacistPermissions PharmacistCompanyPermission[]
  shifts                Shift[]
  shiftSeries           ShiftSeries[]
  managers              User[]
  allowedManagers       User[]                        @relation("ManagerAllowedCompanies")
}

model PharmacistProfile {
  id                  String                        @id @default(uuid())
  userId              String                        @unique
  licenseNumber       String?
  address             String?
  city                String?
  province            String?
  postalCode          String?
  email               String?
  bio                 String?
  experienceYears     Int?
  approved            Boolean
  createdAt           DateTime                      @default(now())
  canViewAllCompanies Boolean                       @default(false)
  canViewPayRates     Boolean                       @default(true)
  companyPermissions  PharmacistCompanyPermission[]
  user                User                          @relation(fields: [userId], references: [id], onDelete: Cascade)
  shifts              Shift[]
}

model PharmacistCompanyPermission {
  id             String            @id @default(uuid())
  pharmacistId   String
  companyId      String
  canViewPayRate Boolean           @default(false)
  createdAt      DateTime          @default(now())
  company        Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  pharmacist     PharmacistProfile @relation(fields: [pharmacistId], references: [id], onDelete: Cascade)

  @@unique([pharmacistId, companyId])
}

model Location {
  id          String        @id @default(uuid())
  name        String        @unique
  email       String?
  phone       String?
  address     String?
  city        String?
  province    String?
  postalCode  String?
  companyId   String
  GSTNumber   String?
  legalName   String?
  timezone    String        @default("America/Edmonton")
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  shifts      Shift[]
  shiftSeries ShiftSeries[]
  managers    User[]

  @@index([companyId])
}

model Shift {
  id           String             @id @default(uuid())
  companyId    String
  locationId   String?
  title        String
  description  String?
  startTime    DateTime
  endTime      DateTime
  payRate      Float
  status       ShiftStatus        @default(open)
  createdAt    DateTime           @default(now())
  pharmacistId String?
  published    Boolean            @default(false)
  seriesId     String?
  company      Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location     Location?          @relation(fields: [locationId], references: [id])
  pharmacist   PharmacistProfile? @relation(fields: [pharmacistId], references: [id])
  series       ShiftSeries?       @relation(fields: [seriesId], references: [id])

  @@index([companyId])
  @@index([locationId])
  @@index([pharmacistId])
  @@index([published])
  @@index([seriesId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(shift)
  actionUrl String?
  seen      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model File {
  id         String    @id @default(uuid())
  userId     String?
  fileName   String
  fileUrl    String
  uploadedAt DateTime  @default(now())
  companyId  String?
  mimeType   String?
  size       Int?
  type       FileType?
  company    Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type], map: "unique_user_resume", where: raw("(type = 'resume'::\"FileType\")"))
  @@unique([userId, type], map: "unique_user_profile_pic", where: raw("(type = 'profilePicture'::\"FileType\")"))
  @@unique([companyId, type], map: "unique_company_logo", where: raw("(type = 'logo'::\"FileType\")"))
}

model ShiftSeries {
  id              String     @id @default(uuid())
  companyId       String
  locationId      String?
  title           String
  description     String?
  payRate         Float
  startMinutes    Int
  endMinutes      Int
  repeatType      RepeatType
  daysOfWeek      Int[]
  startDate       DateTime
  endDate         DateTime
  excludeWeekends Boolean    @default(false)
  published       Boolean    @default(false)
  createdAt       DateTime   @default(now())
  shifts          Shift[]
  company         Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  location        Location?  @relation(fields: [locationId], references: [id])
}

model EmailLog {
  id                String      @id @default(uuid())
  recipientEmail    String
  userId            String?
  subject           String
  templateName      String?
  status            EmailStatus
  providerMessageId String?
  errorMessage      String?
  metadata          Json?
  createdAt         DateTime    @default(now())
  user              User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  admin
  pharmacy_manager
  relief_pharmacist
  location_manager
}

enum ShiftStatus {
  open
  taken
  cancelled
  completed
}

enum NotificationType {
  shift
  system
  payment
  reminder
}

enum FileType {
  resume
  logo
  document
  profilePicture
}

enum RepeatType {
  NONE
  DAILY
  WEEKLY
}

enum EmailStatus {
  sent
  failed
}
